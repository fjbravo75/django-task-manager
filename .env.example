# Django core settings
SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Demo credentials used by `python manage.py seed_demo`
DEMO_USER_PASSWORD=DemoAccess123!

# Leave DATABASE_URL empty to keep the local SQLite fallback.
# For PostgreSQL in server, use something like:
# DATABASE_URL=postgresql://taskmanager:change-me@127.0.0.1:5432/django_task_manager
DATABASE_URL=

# Optional explicit database settings if you prefer not to use DATABASE_URL.
# For local SQLite these values can stay empty.
DB_ENGINE=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
